# Copy to .env and fill in values

# ─── Tailscale ────────────────────────────────────────────────────────────────
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for servers.
TS_AUTHKEY=tskey-auth-xxxx
TS_HOSTNAME=prism

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5432/prism
DATABASE_SYNC_URL=postgresql://prism:prism@localhost:5432/prism

# Legacy direct vars (kept for compatibility)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prism
DB_USER=prism
DB_PASSWORD=prism

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Market APIs ──────────────────────────────────────────────────────────────
# Upbit (암호화폐) — public endpoints work without keys
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# KIS (한국투자증권) — Phase 2
KIS_APP_KEY=
KIS_APP_SECRET=

# ─── Data collection settings ─────────────────────────────────────────────────
DEFAULT_MARKETS=["KRW-BTC","KRW-ETH","KRW-XRP","KRW-SOL","KRW-ADA"]
BACKFILL_DAYS=365

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
