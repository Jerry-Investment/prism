# PRISM — Production Environment
# Copy to .env on the server and fill in all values.
# Never commit the filled .env to git.

# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=prism.yourdomain.com           # e.g. prism.example.com
ACME_EMAIL=admin@yourdomain.com       # Let's Encrypt notifications

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change_me_64_char_random_hex_string

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4

# ─── Market APIs ──────────────────────────────────────────────────────────────
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=

# ─── Image tag (set by deploy workflow, override for manual deploys) ───────────
IMAGE_TAG=production

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=                           # https://sentry.io — leave blank to disable

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set automatically from DOMAIN — override only if needed
# CORS_ORIGINS=["https://prism.yourdomain.com"]
